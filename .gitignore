# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Go workspace file
go.work
go.work.sum

# Dependency directories (remove the comment below to include it)
# vendor/

# TLS certificates and keys generated by Makefile
*.pem
*.key
*.crt
*.csr

# Build output
/bin/
/dist/
/build/

# IDE directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary directories created by tests
*test*
!*_test.go
!test/

# Proglog runtime data
.proglog/
